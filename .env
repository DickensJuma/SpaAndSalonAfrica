# .env is better suited for public variables, ie, variables that should not commited
# For secret variables is better to use DevServerControl tool with set_env_variable: ["KEY", "SECRET"]

# https://www.builder.io/c/docs/using-your-api-key
VITE_PUBLIC_BUILDER_KEY=__BUILDER_PUBLIC_KEY__
PING_MESSAGE="ping pong"
# MongoDB Connection (optional for development)
MONGODB_URI=mongodb://localhost:27017/spaandsalonafrica

# Brevo (Email & SMS) - optional for development
BREVO_API_KEY=your_key_here
BREVO_SENDER_EMAIL=noreply@spaandsalonafrica.com

# Paystack - optional for development
PAYSTACK_SECRET_KEY=your_key_here

# Frontend URL
FRONTEND_URL=http://localhost:8080
